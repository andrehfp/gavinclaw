#!/usr/bin/env bash
set -euo pipefail

ITEM_NAME="${BW_ITEM_NAME:-cazu-dev-env}"

usage() {
  cat <<'EOF'
Usage:
  bin/secrets-exec [item_name] -- <command> [args...]

Examples:
  bin/secrets-exec cazu-dev-env -- mix phx.server
  bin/secrets-exec -- mix test

Notes:
  - Reads dotenv content from Bitwarden item Notes
  - Exports variables only in the current process, then execs your command
  - Does not write to .env
EOF
}

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Error: required command not found: $1" >&2
    exit 1
  fi
}

trim_leading() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  printf '%s' "$s"
}

trim_trailing() {
  local s="$1"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

trim() {
  local s="$1"
  s="$(trim_leading "$s")"
  s="$(trim_trailing "$s")"
  printf '%s' "$s"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ "${1:-}" != "" && "${1:-}" != "--" ]]; then
  ITEM_NAME="$1"
  shift
fi

if [[ "${1:-}" == "--" ]]; then
  shift
fi

if [[ $# -eq 0 ]]; then
  echo "Error: missing command to execute." >&2
  usage
  exit 1
fi

need_cmd bw
need_cmd jq

STATUS_JSON="$(bw status 2>/dev/null || true)"
STATUS="$(printf '%s' "$STATUS_JSON" | jq -r '.status // "unknown"')"

if [[ -z "${BW_SESSION:-}" ]]; then
  case "$STATUS" in
    unauthenticated)
      echo "Bitwarden CLI is not logged in." >&2
      echo "Run: bw login" >&2
      exit 1
      ;;
    locked)
      echo "Bitwarden is locked. Unlocking..." >&2
      export BW_SESSION="$(bw unlock --raw)"
      ;;
  esac
fi

bw sync >/dev/null

ITEM_JSON="$(bw get item "$ITEM_NAME")"
NOTES="$(printf '%s' "$ITEM_JSON" | jq -r '.notes // empty')"

if [[ -z "$NOTES" ]]; then
  echo "Error: item '$ITEM_NAME' has empty notes. Put dotenv content in Notes." >&2
  exit 1
fi

while IFS= read -r line || [[ -n "$line" ]]; do
  line="${line%$'\r'}"
  line="$(trim "$line")"

  [[ -z "$line" ]] && continue
  [[ "${line:0:1}" == "#" ]] && continue

  if [[ "$line" =~ ^export[[:space:]]+ ]]; then
    line="${line#export }"
    line="$(trim_leading "$line")"
  fi

  if [[ ! "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)[[:space:]]*=(.*)$ ]]; then
    echo "Warning: skipping invalid dotenv line: $line" >&2
    continue
  fi

  key="${BASH_REMATCH[1]}"
  value="${BASH_REMATCH[2]}"
  value="$(trim_leading "$value")"

  if [[ "$value" =~ ^\"(.*)\"$ ]]; then
    value="${BASH_REMATCH[1]}"
    value="${value//\\n/$'\n'}"
    value="${value//\\r/$'\r'}"
    value="${value//\\t/$'\t'}"
    value="${value//\\\"/\"}"
    value="${value//\\\\/\\}"
  elif [[ "$value" =~ ^\'(.*)\'$ ]]; then
    value="${BASH_REMATCH[1]}"
  else
    if [[ "$value" =~ ^(.*[^[:space:]])[[:space:]]+#.*$ ]]; then
      value="${BASH_REMATCH[1]}"
    elif [[ "$value" =~ ^[[:space:]]+#.*$ ]]; then
      value=""
    fi
    value="$(trim_trailing "$value")"
  fi

  export "$key=$value"
done <<< "$NOTES"

exec "$@"
