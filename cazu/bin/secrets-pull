#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

ITEM_NAME="${1:-cazu-dev-env}"
OUT_FILE="${2:-.env}"

if [[ "${OUT_FILE}" != /* ]]; then
  OUT_FILE="${REPO_ROOT}/${OUT_FILE}"
fi

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Error: required command not found: $1" >&2
    exit 1
  fi
}

need_cmd bw
need_cmd jq

STATUS_JSON="$(bw status 2>/dev/null || true)"
STATUS="$(printf '%s' "$STATUS_JSON" | jq -r '.status // "unknown"')"

if [[ -z "${BW_SESSION:-}" ]]; then
  case "$STATUS" in
    unauthenticated)
      echo "Bitwarden CLI is not logged in." >&2
      echo "Run: bw login" >&2
      exit 1
      ;;
    locked)
      echo "Bitwarden is locked. Unlocking..." >&2
      export BW_SESSION="$(bw unlock --raw)"
      ;;
  esac
fi

bw sync >/dev/null

ITEM_JSON="$(bw get item "$ITEM_NAME")"
NOTES="$(printf '%s' "$ITEM_JSON" | jq -r '.notes // empty')"

if [[ -z "$NOTES" ]]; then
  echo "Error: item '$ITEM_NAME' has empty notes. Put dotenv content in Notes." >&2
  exit 1
fi

mkdir -p "$(dirname "$OUT_FILE")"
TMP_FILE="$(mktemp "${OUT_FILE}.tmp.XXXXXX")"
trap 'rm -f "$TMP_FILE"' EXIT

printf '%s\n' "$NOTES" > "$TMP_FILE"
chmod 600 "$TMP_FILE"
mv "$TMP_FILE" "$OUT_FILE"

echo "Updated $OUT_FILE from Bitwarden item '$ITEM_NAME'."
