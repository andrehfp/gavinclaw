DATABASE_URL=ecto://postgres:postgres@localhost/cazu_prod
SECRET_KEY_BASE=replace_with_mix_phx_gen_secret
PHX_HOST=your-domain.com
PORT=4000
POOL_SIZE=10
PHX_SERVER=true

CONTA_AZUL_CLIENT_ID=replace_me
CONTA_AZUL_CLIENT_SECRET=replace_me
CONTA_AZUL_REDIRECT_URI=https://your-domain.com/api/auth/conta-azul/callback

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_WEBHOOK_TOKEN=replace_me

LLM_PROVIDER=openai
LLM_WEBSOCKET_MODE_ENABLED=false
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5.2
OPENAI_PRIMARY_MODEL=gpt-5.2
OPENAI_ROUTER_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_WEBSOCKET_BASE_URL=wss://api.openai.com/v1/responses
OPENAI_WEBSOCKET_TIMEOUT_MS=30000
OPENAI_WEBSOCKET_BETA_HEADER=
OPENAI_TIMEOUT_MS=10000
# Optional: comma-free JSON map of model prices per 1M tokens
# Example: {"gpt-4.1-mini":{"input_per_million":0.4,"output_per_million":1.6}}
OPENAI_MODEL_PRICES_JSON={}

AGENT_TRACE_ENABLED=false
AGENT_TRACE_PATH=output/agent_trace.jsonl
AGENT_REQUIRE_WRITE_CONFIRMATION=false
AGENT_LEGACY_COMMAND_FALLBACK_ENABLED=false
AGENT_CONVERSATION_IDLE_TIMEOUT_MS=300000
AGENT_CONVERSATION_PRUNE_INTERVAL_MS=60000
